datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum CampaignStatus {
  DRAFT
  QUEUED
  SENDING
  PAUSED
  COMPLETED
  CANCELLED
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  password   String?  // Opcional para usuários que usam apenas Google OAuth
  email      String?  @unique // E-mail vindo do Google
  googleId   String?  @unique // ID único do Google
  name       String?           // Nome completo do perfil Google
  avatarUrl  String?           // Foto de perfil do Google
  role       UserRole @default(VIEWER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


model Contact {
  id                 String        @id @default(uuid())
  name               String?
  phone              String        @unique
  tags               String[]      @default([])
  groupId            String?
  group              ContactGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  stageId            String?
  stage              CrmStage?     @relation(fields: [stageId], references: [id], onDelete: SetNull)
  logs               MessageLog[]
  chatbotPausedUntil DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model CrmStage {
  id        String    @id @default(uuid())
  name      String    @unique
  color     String    @default("#3b82f6")
  order     Int       @default(0)
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ContactGroup {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  contacts    Contact[]
  campaigns   Campaign[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Template {
  id        String     @id @default(uuid())
  name      String
  body      String
  imageUrl  String?
  campaigns Campaign[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Campaign {
  id               String          @id @default(uuid())
  name             String
  status           CampaignStatus  @default(DRAFT)
  templateId       String
  template         Template        @relation(fields: [templateId], references: [id])
  groupId          String?
  group            ContactGroup?   @relation(fields: [groupId], references: [id])
  segmentId        String?
  segment          ContactSegment? @relation(fields: [segmentId], references: [id])
  delayMin         Int             @default(5)  // mínimo em segundos
  delayMax         Int             @default(15) // máximo em segundos
  messageVariants  String[]        @default([]) // Variantes de texto adicionais (rotação automática)
  batchSize        Int             @default(0)  // Nº de msgs por lote (0 = desabilitado)
  batchCooldown    Int             @default(600) // Pausa entre lotes em segundos (padrão 10min)
  scheduledAt      DateTime?
  logs             MessageLog[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ContactSegment {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  filters     Json       // Filtros JSON: { tags: string[], excludedTags: string[], groupId: string|null, engagement: 'ALL'|'READ'|'DELIVERED' }
  campaigns   Campaign[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model MessageLog {
  id          String        @id @default(uuid())
  campaignId  String
  campaign    Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status      MessageStatus @default(PENDING)
  error       String?
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  updatedAt   DateTime      @updatedAt
}

model WhatsAppInstance {
  id                    String   @id @default(uuid())
  name                  String   @unique
  status                String   @default("DISCONNECTED") // CONNECTED, DISCONNECTED, INITIALIZING
  phone                 String?
  qrCode                String?
  profileName           String?  // Nome do perfil do WhatsApp
  profilePicUrl         String?  // Foto de perfil do WhatsApp
  dailyMsgCount         Int      @default(0)
  healthScore           Int      @default(100) // 0 a 100
  proxy                 String?  // Proxy associada à instância
  unrepliedMsgCount     Int      @default(0)
  maxUnrepliedLimit     Int      @default(20)
  unrepliedBlockEnabled Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

enum WarmupStatus {
  RUNNING
  PAUSED
  STOPPED
  COMPLETED
}

model WarmupCampaign {
  id               String       @id @default(uuid())
  name             String?      // Nome descritivo da campanha
  sourceInstance   String       // Nome da instância que inicia o papo
  targetInstance   String?      // Nome da instância que responde (opcional para bidirecional)
  targetPhone      String       // Telefone da instância destino
  targetPhones     String?      // Lista de telefones separados por vírgula para rotação
  customContext    String?      // Contexto ou Persona customizada de IA
  isGroup          Boolean      @default(false) // Se o aquecimento é para um grupo
  status           WarmupStatus @default(RUNNING)
  currentDay       Int          @default(1)
  totalDays        Int          @default(30)
  msgsSentToday    Int          @default(0)
  targetMsgsToday  Int          @default(5)   // Começa conservador: 5 msgs/dia
  initialMsgsPerDay Int         @default(5)   // Valor inicial do ramp-up
  maxMsgsPerDay    Int          @default(150) // Teto máximo de mensagens por dia
  startHour        Int          @default(8)   // Hora de início (0-23)
  endHour          Int          @default(22)  // Hora de fim (0-23)
  heatScore        Int          @default(0)   // Score de 0-100 estimado de aquecimento
  lastMessageAt    DateTime?                  // Última mensagem enviada
  restPeriodUntil  DateTime?                  // Período de descanso ativo até
  nextRunAt        DateTime?
  enableStatus     Boolean      @default(false)
  statusFrequency  Int          @default(2)
  statusType       String       @default("text") // "text", "image", "random"
  logs             WarmupLog[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum WarmupMessageType {
  TEXT
  EMOJI
  REACTION
  STICKER
  AUDIO
}

model WarmupLog {
  id           String            @id @default(uuid())
  campaignId   String
  campaign     WarmupCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fromInstance String
  toPhone      String
  message      String
  messageType  WarmupMessageType @default(TEXT)
  status       String            @default("SENT") // SENT, DELIVERED, READ, FAILED
  messageId    String?           // ID real da mensagem no WhatsApp (usado para reações)
  delayUsed    Int               @default(0)
  senderName   String?
  createdAt    DateTime          @default(now())
}

model WarmupPool {
  id                String            @id @default(uuid())
  name              String
  status            WarmupStatus      @default(RUNNING)
  instanceNames     String[]          @default([])
  currentDay        Int               @default(1)
  totalDays         Int               @default(30)
  msgsSentToday     Int               @default(0)
  targetMsgsToday   Int               @default(5)
  initialMsgsPerDay Int               @default(5)
  maxMsgsPerDay     Int               @default(150)
  startHour         Int               @default(8)
  endHour           Int               @default(22)
  heatScore         Int               @default(0)
  lastMessageAt     DateTime?
  restPeriodUntil   DateTime?
  nextRunAt         DateTime?
  logs              WarmupPoolLog[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model WarmupPoolLog {
  id           String            @id @default(uuid())
  poolId       String
  pool         WarmupPool        @relation(fields: [poolId], references: [id], onDelete: Cascade)
  fromInstance String
  toInstance   String
  message      String
  messageType  WarmupMessageType @default(TEXT)
  status       String            @default("SENT")
  messageId    String?           // ID real da mensagem no WhatsApp (usado para reações)
  delayUsed    Int               @default(0)
  createdAt    DateTime          @default(now())
}

model ChatbotRule {
  id          String   @id @default(uuid())
  trigger     String   @unique
  matchType   String   @default("EXACT") // EXACT, CONTAINS
  response    String
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatbotConfig {
  id                String   @id @default("global")
  aiEnabled         Boolean  @default(false)
  aiContext         String   @default("Você é um assistente de atendimento virtual prestativo e educado.")
  geminiApiKey      String?
  businessHoursOnly Boolean  @default(false)
  startHour         Int      @default(8)
  endHour           Int      @default(18)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ChatbotLog {
  id         String   @id @default(uuid())
  phone      String
  messageIn  String
  messageOut String
  source     String   // RULE ou AI
  createdAt  DateTime @default(now())
}

model WhatsAppStatus {
  id           String   @id @default(uuid())
  instanceName String
  senderJid    String
  senderName   String?
  mediaType    String   @default("text") // text, image, video, audio
  content      String?
  mediaUrl     String?
  createdAt    DateTime @default(now())
}

