datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum CampaignStatus {
  DRAFT
  QUEUED
  SENDING
  PAUSED
  COMPLETED
  CANCELLED
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String       @id @default(uuid())
  name      String?
  phone     String       @unique
  tags      String[]     @default([])
  groupId   String?
  group     ContactGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  logs      MessageLog[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ContactGroup {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  contacts    Contact[]
  campaigns   Campaign[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Template {
  id        String     @id @default(uuid())
  name      String
  body      String
  imageUrl  String?
  campaigns Campaign[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Campaign {
  id          String         @id @default(uuid())
  name        String
  status      CampaignStatus @default(DRAFT)
  templateId  String
  template    Template       @relation(fields: [templateId], references: [id])
  groupId     String
  group       ContactGroup   @relation(fields: [groupId], references: [id])
  delayMin    Int            @default(5)  // mínimo em segundos
  delayMax    Int            @default(15) // máximo em segundos
  scheduledAt DateTime?
  logs        MessageLog[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model MessageLog {
  id          String        @id @default(uuid())
  campaignId  String
  campaign    Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status      MessageStatus @default(PENDING)
  error       String?
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  updatedAt   DateTime      @updatedAt
}

model WhatsAppInstance {
  id        String   @id @default(uuid())
  name      String   @unique
  status    String   @default("DISCONNECTED") // CONNECTED, DISCONNECTED, INITIALIZING
  phone     String?
  qrCode    String?
  updatedAt DateTime @updatedAt
}

enum WarmupStatus {
  RUNNING
  PAUSED
  STOPPED
  COMPLETED
}

model WarmupCampaign {
  id               String       @id @default(uuid())
  name             String?      // Nome descritivo da campanha
  sourceInstance   String       // Nome da instância que inicia o papo
  targetInstance   String?      // Nome da instância que responde (opcional para bidirecional)
  targetPhone      String       // Telefone da instância destino
  status           WarmupStatus @default(RUNNING)
  currentDay       Int          @default(1)
  totalDays        Int          @default(30)
  msgsSentToday    Int          @default(0)
  targetMsgsToday  Int          @default(5)   // Começa conservador: 5 msgs/dia
  initialMsgsPerDay Int         @default(5)   // Valor inicial do ramp-up
  maxMsgsPerDay    Int          @default(150) // Teto máximo de mensagens por dia
  startHour        Int          @default(8)   // Hora de início (0-23)
  endHour          Int          @default(22)  // Hora de fim (0-23)
  heatScore        Int          @default(0)   // Score de 0-100 estimado de aquecimento
  lastMessageAt    DateTime?                  // Última mensagem enviada
  restPeriodUntil  DateTime?                  // Período de descanso ativo até
  nextRunAt        DateTime?
  logs             WarmupLog[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum WarmupMessageType {
  TEXT
  EMOJI
  REACTION
  STICKER
  AUDIO
}

model WarmupLog {
  id           String            @id @default(uuid())
  campaignId   String
  campaign     WarmupCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fromInstance String
  toPhone      String
  message      String
  messageType  WarmupMessageType @default(TEXT)
  status       String            @default("SENT") // SENT, DELIVERED, READ, FAILED
  delayUsed    Int               @default(0)
  createdAt    DateTime          @default(now())
}
